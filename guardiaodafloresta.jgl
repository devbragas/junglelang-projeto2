    "arara-azul-de-lear": "Um grasnar metálico colore o céu de azul intenso."
}

NASCER acoes = {
    "ariranha": "Mantenha distância, não alimente e avise órgãos ambientais como Ibama ou ICMBio.",
    "peixe-boi-da-amazonia": "Não toque, não tente empurrar para a água e acione uma equipe de resgate especializada.",
    "boto-cor-de-rosa": "Não ofereça comida, evite barcos muito próximos e informe autoridades ambientais.",
    "onca-pintada": "Afaste-se com calma, não corra, proteja pessoas e acione imediatamente a vigilância ambiental.",
    "uacari-branco": "Não tente capturar, reduza barulho e comunique pesquisadores ou fiscais da região.",
    "macaco-aranha": "Não aproxime alimento humano, observe de longe e avise a gestão da unidade de conservação.",
    "jacare-acu": "Mantenha distância segura, não provoque e preserve a área sem interferência.",
    "anta": "Deixe uma rota de fuga livre, não encurrale e informe se houver ferimentos.",
    "sauim-de-coleira": "Evite contato, não retire do habitat e acione um centro de fauna.",
    "harpia": "Observe de longe, não se aproxime do ninho e informe órgãos ambientais.",
    "mutum-de-penacho": "Não capture, evite desmatamento local e comunique equipes de conservação.",
    "tatu-canastra": "Não bloqueie tocas, mantenha distância e informe registros a projetos de monitoramento.",
    "tamandua-bandeira": "Não toque, afaste cães e pessoas e chame apoio ambiental se estiver ferido.",
    "cuxiu-preto": "Reduza perturbações, não alimente e comunique agentes de preservação.",
    "gaviao-real": "Proteja a área do ninho, evite ruído e informe autoridades competentes.",
    "tracaja": "Não recolha ovos nem filhotes e acione programas locais de proteção de quelônios.",
    "pirarucu": "Respeite períodos de manejo, não pesque irregularmente e informe a comunidade local.",
    "jaguatirica": "Mantenha distância, não tente seguir o animal e evite qualquer captura.",
    "queixada": "Afaste-se do grupo, não provoque e preserve corredores florestais.",
    "arara-azul-de-lear": "Não se aproxime de paredões de nidificação, não alimente e avise o ICMBio."
}

NASCER selo = {
    "ariranha": "** ESPÉCIE-CHAVE DOS RIOS AMAZÔNICOS **",
    "peixe-boi-da-amazonia": "** GIGANTE PACÍFICO EM RISCO **",
    "boto-cor-de-rosa": "** LENDA VIVA DO RIO **",
    "onca-pintada": "** TOPO DA CADEIA ALIMENTAR **",
    "uacari-branco": "** RARO E ENDÊMICO DA AMAZÔNIA **",
    "macaco-aranha": "** ACROBATA DAS COPAS **",
    "jacare-acu": "** SENTINELA DOS IGAPÓS **",
    "anta": "** JARDINEIRA DA FLORESTA **",
    "sauim-de-coleira": "** PEQUENO E VULNERÁVEL **",
    "harpia": "** RAINHA DOS CÉUS AMAZÔNICOS **",
    "mutum-de-penacho": "** AVE EMBLEMÁTICA DA MATA **",
    "tatu-canastra": "** ENGENHEIRO DO SUBSOLO **",
    "tamandua-bandeira": "** GUARDIÃO DOS FORMIGUEIROS **",
    "cuxiu-preto": "** HABITANTE DAS COPAS ALTAS **",
    "gaviao-real": "** PREDADOR DE ELITE **",
    "tracaja": "** VIAJANTE DOS RIOS **",
    "pirarucu": "** GIGANTE DAS ÁGUAS DOCES **",
    "jaguatirica": "** CAÇADORA NOTURNA E DISCRETA **",
    "queixada": "** ARQUITETA DOS CORREDORES VERDES **",
    "arara-azul-de-lear": "** JOIA AZUL DO SERTÃO E DA MATA **"
}

NASCER encontrado = 0

ENQUANTO animal in especies
    NASCER encontrado = 1

    RUGIR " "
    RUGIR "------------------------------------------------------------"
    RUGIR sons[animal]
    RUGIR "Espécie identificada:"
    RUGIR nomes[animal]
    RUGIR selo[animal]

    NASCER ameacado = especies[animal]

    ENQUANTO ameacado > 0
        RUGIR "Status: EM PERIGO DE EXTINÇÃO."
        RUGIR "O Guardião da Floresta alerta: protocolo de segurança!"
        RUGIR "O que fazer ao encontrar esse animal:"
        RUGIR acoes[animal]
        NASCER ameacado = 0
    FOME

    ENQUANTO especies[animal] == 0
        RUGIR "Status: sem indicação de perigo imediato nesta lista."
        RUGIR "Mesmo fora da lista de risco, a floresta agradece o cuidado:"
        RUGIR acoes[animal]
        NASCER especies[animal] = -1
    FOME

    RUGIR "------------------------------------------------------------"
    NASCER animal = ""
FOME

ENQUANTO encontrado == 0
    RUGIR " "
    RUGIR "O Guardião não reconheceu esse rastro na floresta."
    RUGIR "Animal não encontrado na lista do programa."
    RUGIR "Digite exatamente como aparece na lista apresentada."
    NASCER encontrado = 1
FOME

RUGIR " "
RUGIR "============================================================"
RUGIR "Consulta encerrada. A Amazônia agradece sua vigilância!"
RUGIR "============================================================"
