    "tamandua-bandeira": 1,
    "cuxiu-preto": 1,
    "gaviao-real": 1,
    "tracaja": 1,
    "pirarucu": 0,
    "jaguatirica": 0,
    "queixada": 0,
    "arara-azul-de-lear": 1
}

NASCER nomes = {
    "ariranha": "Ariranha",
    "peixe-boi-da-amazonia": "Peixe-boi-da-Amazônia",
