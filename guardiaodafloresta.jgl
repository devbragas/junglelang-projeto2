}

NASCER sons = {
    "ariranha": "Um assovio agudo corta o rio: a ariranha avisa o bando.",
    "peixe-boi-da-amazonia": "Um borbulhar manso na água escura denuncia o gigante gentil.",
    "boto-cor-de-rosa": "Um salto rosado quebra a superfície do rio sob o sol.",
    "onca-pintada": "Um rosnado grave faz as folhas tremerem ao redor.",
    "uacari-branco": "Uma sombra de pelagem clara passa veloz entre os galhos altos.",
    "macaco-aranha": "Gritos agudos ecoam de copa em copa da mata.",
    "jacare-acu": "Um par de olhos flutua quieto na superfície da lagoa.",
    "anta": "Passos pesados e um resfolegar grave atravessam a trilha.",
    "sauim-de-coleira": "Um chilrear fino denuncia o pequeno primata camuflado.",
    "harpia": "Um bater de asas poderoso escurece o céu por um instante.",
